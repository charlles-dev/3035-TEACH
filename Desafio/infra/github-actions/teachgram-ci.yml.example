name: TeachGram Pro CI

on:
  pull_request:
    paths:
      - "Desafio/**"
  push:
    branches:
      - main
    paths:
      - "Desafio/**"

jobs:
  backend:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: Desafio/backend
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "21"
          cache: maven
      - run: ./mvnw test

  frontend:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: Desafio/frontend
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "22"
          cache: npm
          cache-dependency-path: Desafio/frontend/package-lock.json
      - run: npm ci
      - run: npm audit
      - run: npm run build
