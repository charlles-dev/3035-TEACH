# TeachGram Pro - local development

# Backend
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8081

DATABASE_URL=jdbc:postgresql://localhost:55432/teachgram
DATABASE_USERNAME=teachgram
DATABASE_PASSWORD=teachgram

JWT_SECRET=change-me-to-a-long-random-secret-with-at-least-32-characters
JWT_ACCESS_TOKEN_TTL=PT15M
JWT_REFRESH_TOKEN_TTL=P30D
SECURE_COOKIES=false

CORS_ALLOWED_ORIGINS=http://localhost:5173

REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_AI_PER_HOUR=20
OUTBOX_PROCESS_DELAY_MS=30000

AI_ENABLED=false
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TEXT_MODEL=groq/compound
GROQ_FAST_MODEL=groq/compound-mini
GROQ_MODEL_VERSION=
AI_TIMEOUT_MS=8000
AI_DAILY_LIMIT_PER_USER=30
AI_FALLBACK_ENABLED=true

SUPABASE_STORAGE_ENABLED=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLIC_BUCKET=teachgram-media

# Frontend
VITE_API_BASE_URL=http://localhost:8081/api/v1
VITE_APP_NAME=TeachGram Pro
VITE_DEMO_EMAIL=demo@teachgram.pro
